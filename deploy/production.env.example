# Telegram
BOT_TOKEN=replace_with_bot_token
ADMIN_TELEGRAM_IDS=123456789

# Application
NODE_ENV=production
TZ=Europe/Moscow
LOG_LEVEL=info
REMIND_DAYS_BEFORE=3
REMINDERS_ENABLED=true
REMINDER_SEND_HOUR=10
REMINDER_CHECK_INTERVAL_MINUTES=60
INVITE_EXPIRES_HOURS=168
SUPPORT_USERNAME=@your_username
PAYMENT_RECIPIENT=Recipient Name
PAYMENT_DETAILS=Payment details for users

# PostgreSQL container configuration
POSTGRES_DB=vpn_payments
POSTGRES_USER=vpn_bot
POSTGRES_PASSWORD=replace_with_strong_password
