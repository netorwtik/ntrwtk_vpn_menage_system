# Telegram
BOT_TOKEN=replace_with_new_bot_token
ADMIN_TELEGRAM_IDS=123456789

# Application
NODE_ENV=development
TZ=Europe/Moscow
LOG_LEVEL=info
REMIND_DAYS_BEFORE=3
REMINDERS_ENABLED=true
REMINDER_SEND_HOUR=10
REMINDER_CHECK_INTERVAL_MINUTES=60
INVITE_EXPIRES_HOURS=168
SUPPORT_USERNAME=@your_username
PAYMENT_RECIPIENT=Имя Фамилия
PAYMENT_DETAILS=СБП по номеру +7 900 000-00-00, Банк

# PostgreSQL for local commands executed from the host machine
DATABASE_URL=postgresql://vpn_bot:change_me@127.0.0.1:55432/vpn_payments?schema=public

# PostgreSQL container configuration
POSTGRES_DB=vpn_payments
POSTGRES_USER=vpn_bot
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=55432
